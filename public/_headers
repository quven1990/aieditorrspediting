# Default: do not cache HTML at browser or Cloudflare edge.
# After each deploy, CSS/JS filenames change; stale HTML → 404 on old /_next/static/* assets.
/*
  Cache-Control: no-cache, must-revalidate
  CDN-Cache-Control: no-store
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# Hashed build assets — safe to cache forever (filename changes every build).
/_next/static/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/_next/*
  Cache-Control: public, max-age=31536000, immutable
  CDN-Cache-Control: max-age=31536000

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
  Cache-Control: public, max-age=3600
  CDN-Cache-Control: max-age=3600

/robots.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
  CDN-Cache-Control: max-age=3600

/ads.txt
  Content-Type: text/plain; charset=utf-8
  Cache-Control: public, max-age=3600
  CDN-Cache-Control: max-age=3600
